{
    "name": "chrisp/events-invite-manager",
    "description": "WordPress plugin for managing event invitations and registrations",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "EventsInviteManager\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
